# ─── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Use ONE of the following public keys (publishable preferred on new projects):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-jwt

# Server-only privileged key — used only by the admin client for trusted jobs.
# Optional for Phase 1. Use the new secret key OR the legacy service_role JWT.
SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-jwt

# ─── AI Router & Providers ────────────────────────────────────────────────
# The router uses a provider DIRECTLY when its key is set, else routes the same
# model through OpenRouter. OpenRouter is also the universal fallback.

# Google Gemini — direct chat (quiz/summary/flashcards) AND embeddings for RAG.
# https://aistudio.google.com/apikey  — server-only. Required for RAG.
GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY=                      # accepted as an alias for GEMINI_API_KEY

# OpenRouter — fallback + routes models without a direct key (Claude, GPT).
# https://openrouter.ai/keys  — server-only.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# Universal fallback model id (any from https://openrouter.ai/models)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=MedMate AI

# Optional — add a key to route these tasks to a DIRECT provider (else OpenRouter):
# ANTHROPIC_API_KEY=                   # study planner (Claude Sonnet)
# OPENAI_API_KEY=                      # complex medical reasoning (GPT)

# ─── File processing (optional premium; free stack used when unset) ───────────
# Free by default: pdf-parse (PDF), mammoth (DOCX), Tesseract.js (image OCR).
# LLAMAPARSE_API_KEY=                  # premium PDF parsing (LlamaParse)
# GOOGLE_VISION_API_KEY=               # premium OCR (Google Vision)

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
